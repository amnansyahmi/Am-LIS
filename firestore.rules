rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return true; } // Bypassed for development
    function isAdmin() { return true; } // Bypassed for development
    function isTechnician() { return true; } // Bypassed for development
    function isDoctor() { return true; } // Bypassed for development

    // Default deny (keep as fallback)
    match /{document=**} {
      allow read, write: if true; 
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /patients/{patientId} {
      allow read: if isSignedIn();
      allow write: if isTechnician();
    }

    match /tests/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isDoctor() || isTechnician();
      allow update: if isTechnician();
    }

    match /results/{resultId} {
      allow read: if isSignedIn();
      allow write: if isTechnician();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
